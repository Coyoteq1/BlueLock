{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VAutoArena.arena_territory.schema.json",
  "title": "VAutoArena Territory Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["center", "radius"],
  "properties": {
    "center": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    },
    "radius": { "type": "number", "exclusiveMinimum": 0 },
    "gridIndex": { "type": "integer" },
    "regionType": { "type": "integer" },
    "blockSize": { "type": "number", "exclusiveMinimum": 0 }
  }
}
