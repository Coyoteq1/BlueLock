  </ItemGroup>

  <ItemGroup>
    <Content Include="Configuration\*.toml">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Core\PrefabGuidConverter.cs" />
    <Compile Remove="Services\Interfaces\IService.cs" />
  </ItemGroup>

</Project>
