    </Reference>
    <Reference Include="ProjectM.Gameplay.Scripting">
      <HintPath>..\VAutomationCore\libs\ProjectM.Gameplay.Scripting.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="ProjectM.Shared">
      <HintPath>..\VAutomationCore\libs\ProjectM.Shared.dll</HintPath>
