{
  "name": "vrising-admin-tools",
  "version": "1.0.0",
  "description": "V Rising Admin GUI Tool for managing automation plugins",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "keywords": [
    "v-rising",
    "admin",
    "gui",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "goober": "^2.1.18",
    "react": "^18.2.0",
    "react-dom": "^19.3.0-canary-fd524fe0-20251121",
    "zustand": "^5.0.11"
  },
  "build": {
    "appId": "com.vrising.admin-tools",
    "productName": "V Rising Admin Tools",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}